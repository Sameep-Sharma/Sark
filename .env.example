# ──────────────────────────────────────────────────────────────
# SARK Quiz Platform — Environment Variable Reference
# ──────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.

# Required: Supabase Connection
# Get yours from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Optional: HMAC secret for signing session tokens
# If omitted, NEXT_PUBLIC_SUPABASE_URL is used as fallback (fine for dev, not for prod).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
